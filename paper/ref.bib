@article{ghosh1973,
  title = {Some {{Monotonicity Theorems}} for {$\chi$}2, {{F}} and {{T Distributions}} with {{Applications}}},
  author = {Ghosh, B. K.},
  year = 1973,
  month = jul,
  journal = {Journal of the Royal Statistical Society: Series B (Methodological)},
  volume = {35},
  number = {3},
  pages = {480--492},
  issn = {0035-9246},
  doi = {10.1111/j.2517-6161.1973.tb00976.x},
  urldate = {2025-09-23},
  abstract = {The probability that a non-central {$\chi$}2, F or t variable exceeds c is a function of c, the degrees of freedom and the non-centrality parameter. The behaviour of these probabilities as functions of the degrees of freedom is investigated when c and the non-centrality parameters are fixed. It is also shown that, when c refers to the 100{$\alpha\%$} point of the corresponding central distribution, the probabilities are monotone in the degrees of freedom. Some allied results and possible applications are discussed.}
}

